# OpenRouteService — free tier, sign up at https://openrouteservice.org/dev/#/signup
ORS_TOKEN=

# Hugging Face — create a read token at https://huggingface.co/settings/tokens
# (accept the Llama 3.2 license once on the model page using the same account)
HF_TOKEN=
HF_MODEL_ID=meta-llama/Llama-3.2-3B-Instruct

# Nominatim requires a contact UA per their usage policy
NOMINATIM_USER_AGENT=routefit-local (your-email@example.com)
